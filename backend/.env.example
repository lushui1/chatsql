# ChatSQL Environment Configuration
# Copy to .env and fill in your values

# ── LLM Provider ──
# Supported: openai, anthropic, google, dashscope, zhipu, moonshot, deepseek, ollama, custom
CHATSQL_LLM_PROVIDER=openai
CHATSQL_LLM_API_KEY=sk-your-key-here
# Leave empty to use provider default; set for custom or to override
CHATSQL_LLM_BASE_URL=
CHATSQL_LLM_MODEL=gpt-4o-mini
CHATSQL_LLM_THINK_MODEL=gpt-4o
CHATSQL_LLM_TEMPERATURE=0.3
CHATSQL_LLM_MAX_TOKENS=4096

# ── Provider Examples ──
# OpenAI:
#   CHATSQL_LLM_PROVIDER=openai
#   CHATSQL_LLM_API_KEY=sk-xxx
#   CHATSQL_LLM_MODEL=gpt-4o-mini

# Anthropic (Claude):
#   CHATSQL_LLM_PROVIDER=anthropic
#   CHATSQL_LLM_API_KEY=sk-ant-xxx
#   CHATSQL_LLM_MODEL=claude-sonnet-4-20250514

# Google (Gemini):
#   CHATSQL_LLM_PROVIDER=google
#   CHATSQL_LLM_API_KEY=AIza-xxx
#   CHATSQL_LLM_MODEL=gemini-2.0-flash

# 阿里通义千问 (DashScope/Qwen):
#   CHATSQL_LLM_PROVIDER=dashscope
#   CHATSQL_LLM_API_KEY=sk-xxx
#   CHATSQL_LLM_MODEL=qwen-max

# 智谱 (GLM):
#   CHATSQL_LLM_PROVIDER=zhipu
#   CHATSQL_LLM_API_KEY=xxx.xxx
#   CHATSQL_LLM_MODEL=glm-4-plus

# 月之暗面 (Moonshot/Kimi):
#   CHATSQL_LLM_PROVIDER=moonshot
#   CHATSQL_LLM_API_KEY=sk-xxx
#   CHATSQL_LLM_MODEL=moonshot-v1-128k

# DeepSeek:
#   CHATSQL_LLM_PROVIDER=deepseek
#   CHATSQL_LLM_API_KEY=sk-xxx
#   CHATSQL_LLM_MODEL=deepseek-chat

# Ollama (local):
#   CHATSQL_LLM_PROVIDER=ollama
#   CHATSQL_LLM_MODEL=llama3.1

# Custom (any OpenAI-compatible API):
#   CHATSQL_LLM_PROVIDER=custom
#   CHATSQL_LLM_API_KEY=your-key
#   CHATSQL_LLM_BASE_URL=https://your-api-endpoint/v1
#   CHATSQL_LLM_MODEL=your-model-name

# ── Database (sessions/feedback) ──
CHATSQL_DATABASE_URL=sqlite+aiosqlite:///./data/chatsql.db

# ── DataSource (OLAP) ──
CHATSQL_DATASOURCE_TYPE=duckdb
CHATSQL_DATASOURCE_URL=
CHATSQL_DATASOURCE_SCHEMA=main

# Multi-source: JSON config for multiple data sources
# CHATSQL_DATASOURCES_JSON={"sources":[{"name":"mysql-prod","type":"mysql","host":"10.0.0.1","port":3306,"database":"analytics","username":"reader","password":"xxx"},{"name":"doris-olap","type":"doris","host":"10.0.0.2","port":9030,"database":"dw","username":"reader","password":"xxx"}]}
# Or use data/sources.json file (auto-loaded)

# ── Security ──
CHATSQL_API_KEY=
CHATSQL_ADMIN_KEY=

# ── App ──
CHATSQL_DEBUG=true
CHATSQL_HOST=0.0.0.0
CHATSQL_PORT=8000
